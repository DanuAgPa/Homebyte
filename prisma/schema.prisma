generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int             @id @default(autoincrement())
  name            String
  email           String          @unique
  password        String
  role            Role            @default(USER)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  phone           String?
  bio             String?
  inquiries       Inquiry[]
  savedProperties SavedProperty[]

  @@map("users")
}

model Property {
  id              Int             @id @default(autoincrement())
  title           String
  description     String
  price           Float
  address         String
  city            String
  category        Category
  bedrooms        Int
  bathrooms       Int
  areaSquareMeter Float
  imageUrl        String
  isFeatured      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  inquiries       Inquiry[]
  savedByUsers    SavedProperty[]
  shipments       Shipment[]

  @@unique([title, address])
  @@map("properties")
}

model SavedProperty {
  id         Int      @id @default(autoincrement())
  userId     Int
  propertyId Int
  savedAt    DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("saved_properties")
}

model Inquiry {
  id          Int       @id @default(autoincrement())
  message     String
  contactDate DateTime?
  userId      Int?
  propertyId  Int?
  createdAt   DateTime  @default(now())
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("inquiries")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}

model Inventory {
  id           Int      @id @default(autoincrement())
  name         String
  stock        Int
  reorderPoint Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("inventories")
}

model Shipment {
  id            Int            @id @default(autoincrement())
  status        ShipmentStatus @default(PENDING)
  estimatedDate DateTime
  propertyId    Int
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("shipments")
}

enum Role {
  USER
  ADMIN
}

enum Category {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
}
